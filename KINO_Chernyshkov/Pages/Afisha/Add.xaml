<Page x:Class="KINO_Chernyshkov.Pages.Afisha.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KINO_Chernyshkov.Pages.Afisha"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid Background="Gainsboro">
        <Grid Margin="20" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Width="80" Height="80" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10" Source="/Images/ic-kino.png"/>
                <Label Content="Кинотеатр:" Grid.Column="1" VerticalAlignment="Top" Margin="10"/>
                <ComboBox x:Name="kinoteatr" Height="25" Grid.Column="1" Margin="10,36,10,0" VerticalAlignment="Top"/>
                <Label Content="Фильм:" Grid.Column="1" VerticalAlignment="Top" Margin="10,66,10,0"/>
                <TextBox x:Name="name" Height="25" Grid.Column="1" Margin="10,92,10,0" VerticalAlignment="Top"/>
                <Label Content="Дата сеанса:" Grid.Column="2" VerticalAlignment="Top" Margin="10,10,10,0"/>
                <DatePicker x:Name="date" Height="25" Grid.Column="2" Margin="10,36,135,0" VerticalAlignment="Top"/>
                <TextBox x:Name="time" Height="25" Grid.Column="2" Margin="200,36,10,0" VerticalAlignment="Top" ToolTip="ЧЧ:мм"/>
                <Label Content="Стоимость билета:" Grid.Column="2" VerticalAlignment="Top" Margin="10,66,10,0"/>
                <TextBox x:Name="price" Height="25" Grid.Column="2" Margin="10,92,10,0" VerticalAlignment="Top"/>
            </Grid>

            <Grid Grid.Row="1">
                <Button x:Name="bthAdd" Click="AddRecord" Content="Добавить" Height="25" Width="100" Background="#ff73e618" BorderBrush="#ff73e618" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
