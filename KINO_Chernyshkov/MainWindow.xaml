<Window x:Class="KINO_Chernyshkov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KINO_Chernyshkov"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <Grid DockPanel.Dock="Top" Height="40" Background="WhiteSmoke">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">
                <Button Click="OpenKino" Content="Кинотеатры" Width="120" Height="25" Margin="0,0,10,0" Background="#ff73e618" BorderBrush="#ff73e618"/>
                <Button Click="OpenAfisha" Content="Афиша" Width="100" Height="25" Background="#ff73e618" BorderBrush="#ff73e618"/>
            </StackPanel>
        </Grid>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden"/>
    </DockPanel>
</Window>
